/* GogMail TUI Layout & Dimensions Stylesheet */

#app-layout-with-ai {
    layout: horizontal;
    height: 100%;
}

#sidebar {
    height: 100%;
    width: 26;
}

#sidebar-badge {
    dock: bottom;
    height: 1;
    width: 100%;
    content-align: center middle;
    text-style: italic;
    opacity: 70%;
}

#content-switcher {
    width: 1fr;
    height: 100%;
}

#sidebar-header {
    width: 100%;
    height: 3;
    content-align: center middle;
}

#sidebar-compose-btn {
    margin: 1 2;
    width: 22;
    height: 1;
    text-style: bold;
    border: none;
}

#sidebar-tree {
    border: none;
    padding-left: 1;
    padding-right: 1;
}

#main-content {
    height: 100%;
}

.service-view {
    height: 100%;
    layout: vertical;
}

.view-header {
    height: 100%;
    content-align: left middle;
    padding-left: 2;
    text-style: bold;
}

/* Header Rows & Search Inputs */
#gmail-header-row, #drive-header-row, #contacts-header-row, .view-header-row {
    layout: horizontal;
    height: 3;
}

#gmail-header-row Label, #drive-header-row Label, #contacts-header-row Label, .view-header-row Label {
    height: 100%;
    content-align: left middle;
    padding-left: 2;
    padding-right: 2;
    text-style: bold;
    border: none;
    width: auto;
}

#gmail-header-row Input, #drive-header-row Input, #contacts-header-row Input {
    height: 100%;
    border: none;
}

.header-buttons {
    layout: horizontal;
    width: 1fr;
    height: 100%;
    align: right middle;
    padding-right: 1;
}

.header-buttons Button {
    margin-left: 1;
    border: none;
    height: 1;
    min-width: 12;
}

/* Gmail View Switcher */
#gmail-switcher {
    height: 1fr;
    width: 100%;
}

#gmail-list-view {
    height: 1fr;
}

#email-table {
    height: 1fr;
    width: 100%;
}

#gmail-detail-view {
    height: 1fr;
}

#email-body-view {
    height: 1fr;
    width: 100%;
    padding: 1;
}

/* Calendar View */
#calendar-content-row {
    layout: horizontal;
    height: 1fr;
}

#calendar-table {
    width: 65fr;
    height: 100%;
}

#calendar-detail {
    width: 35fr;
    height: 100%;
}

/* Drive View */
#drive-table {
    height: 1fr;
    width: 100%;
}

/* Docs View */
#docs-content-row {
    layout: horizontal;
    height: 1fr;
}

#docs-table {
    width: 35fr;
    height: 100%;
}

#doc-viewer {
    width: 65fr;
    height: 100%;
    padding: 1;
}

/* Sheets View */
#sheets-content-row {
    layout: horizontal;
    height: 1fr;
}

#sheets-list-table {
    width: 30fr;
    height: 100%;
}

#sheet-grid {
    width: 70fr;
    height: 100%;
}

/* Slides & Forms View */
#slides-table, #forms-table {
    height: 1fr;
    width: 100%;
}

/* Meet & Zoom View */
#meet-container, #zoom-container {
    padding: 2;
    height: 1fr;
}

#meet-container .description, #zoom-container .description {
    margin-bottom: 1;
}

#meet-container Button, #zoom-container Button {
    margin-left: 0;
    margin-bottom: 1;
    width: 30;
}

#meet-output, #zoom-output {
    height: 1fr;
    padding: 1;
}

/* Contacts View */
#contacts-content-row {
    layout: horizontal;
    height: 1fr;
}

#contacts-table {
    width: 50fr;
    height: 100%;
}

#contact-detail {
    width: 50fr;
    height: 100%;
    padding: 1;
}

/* Tasks View */
#tasks-content-split {
    layout: horizontal;
    height: 1fr;
}

#tasklists-table {
    width: 30fr;
    height: 100%;
}

#tasks-table {
    width: 70fr;
    height: 100%;
}

/* Chat View */
#chat-split {
    layout: horizontal;
    height: 1fr;
}

#chat-spaces-table {
    width: 30fr;
    height: 100%;
}

#chat-message-pane {
    width: 70fr;
    height: 100%;
    layout: vertical;
}

#chat-history {
    height: 1fr;
    padding: 1;
}

#chat-input {
    height: 3;
    border: none;
}

/* AI Assistant Drawer Splitter */
#ai-splitter {
    width: 1;
    height: 100%;
}

/* AI Assistant Drawer */
#ai-drawer {
    height: 100%;
    layout: vertical;
    width: 40;
}

#ai-header {
    width: 100%;
    height: 3;
    content-align: center middle;
    text-style: bold;
}

#ai-chat-history {
    height: 1fr;
    padding: 1;
}

#ai-input-row {
    height: 3;
    layout: horizontal;
}

#ai-input {
    height: 3;
    width: 1fr;
    border: none;
}

#ai-mic-btn {
    height: 3;
    min-width: 8;
    border: none;
}

.settings-section {
    text-style: bold;
    margin-top: 1;
}

.settings-hint {
    margin-top: 1;
    opacity: 70%;
}

.ai-message {
    margin-bottom: 1;
    padding: 1;
}

/* Buttons and utilities */
.btn-row {
    layout: horizontal;
    height: 1;
    align: right middle;
    padding-right: 1;
}

Button {
    margin-left: 1;
    border: none;
    height: 1;
    min-width: 12;
}

.cal-nav-btn {
    min-width: 5;
}
#cal-today-btn {
    min-width: 8;
}
.cal-view-toggle {
    min-width: 8;
}

/* Dialogs / Modals styling */
#dialog-container {
    padding: 1 2;
    width: 60;
    height: auto;
    align: center middle;
}

#gmail-compose-container {
    padding: 1 2;
    width: 100%;
    height: 100%;
}

.dialog-title {
    text-style: bold;
    margin-bottom: 1;
    content-align: center middle;
}

.multi-line-input {
    height: 6;
}

#email-body {
    height: 1fr;
    margin-bottom: 1;
}

#gemini-label {
    text-style: bold;
}


/* ========================================================================= */
/* THEMES CONFIGURATIONS                                                     */
/* ========================================================================= */

/* 1. GRUVBOX DARK (Default) */
.theme-gruvbox Screen {
    background: #282828;
    color: #ebdbb2;
}
.theme-gruvbox #sidebar {
    background: #1d2021;
    border-right: solid #504945;
}
.theme-gruvbox #sidebar-header {
    background: #282828;
    color: #fabd2f;
    border-bottom: solid #504945;
}
.theme-gruvbox #sidebar-compose-btn {
    background: #b8bb26;
    color: #282828;
}
.theme-gruvbox .view-header {
    color: #fe8019;
}
.theme-gruvbox #gmail-header-row, .theme-gruvbox #drive-header-row, .theme-gruvbox #contacts-header-row, .theme-gruvbox .view-header-row {
    background: #32302f;
    border-bottom: solid #504945;
}
.theme-gruvbox #calendar-detail,
.theme-gruvbox #doc-viewer,
.theme-gruvbox #sheet-grid,
.theme-gruvbox #chat-message-pane,
.theme-gruvbox #contact-detail,
.theme-gruvbox #tasks-table {
    background: #32302f;
    border-left: solid #504945;
}
.theme-gruvbox #ai-drawer {
    background: #32302f;
    border-left: solid #504945;
}
.theme-gruvbox #email-body-view,
.theme-gruvbox #meet-container,
.theme-gruvbox #zoom-container {
    background: #32302f;
}
.theme-gruvbox Button.-primary {
    background: #83a598;
    color: #282828;
}
.theme-gruvbox Button.-success {
    background: #b8bb26;
    color: #282828;
}
.theme-gruvbox Button.-error {
    background: #fb4934;
    color: #282828;
}
.theme-gruvbox DataTable {
    background: #282828;
    color: #ebdbb2;
}
.theme-gruvbox RichLog {
    background: #32302f;
    color: #ebdbb2;
}
.theme-gruvbox Input {
    background: #1d2021;
    color: #ebdbb2;
    border: solid #504945;
}
.theme-gruvbox Tree {
    background: transparent;
    color: #ebdbb2;
}
.theme-gruvbox Tree > TreeNavigation {
    color: #ebdbb2;
}
.theme-gruvbox #ai-drawer {
    background: #32302f;
    border-left: solid #504945;
}
.theme-gruvbox #ai-header {
    background: #282828;
    color: #fabd2f;
    border-bottom: solid #504945;
}
.theme-gruvbox .ai-message.user {
    background: #504945;
    color: #ebdbb2;
}
.theme-gruvbox .ai-message.gemini {
    background: #282828;
    color: #b8bb26;
    border-left: solid #b8bb26;
}
.theme-gruvbox #dialog-container, .theme-gruvbox #gmail-compose-container {
    background: #32302f;
    border: double #fabd2f;
}
.theme-gruvbox .dialog-title {
    color: #fe8019;
}
.theme-gruvbox .multi-line-input, .theme-gruvbox #email-body {
    background: #282828;
    border: solid #504945;
}
.theme-gruvbox #gemini-label {
    color: #b8bb26;
}
.theme-gruvbox Footer {
    background: #1d2021;
    color: #a89984;
}

