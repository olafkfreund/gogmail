    background: #073642;
    border-right: solid #586e75;
}
.theme-solarized #sidebar-header {
    background: #002b36;
    color: #268bd2;
    border-bottom: solid #586e75;
}
.theme-solarized #sidebar-compose-btn {
    background: #859900;
    color: #002b36;
}
.theme-solarized .view-header {
    color: #cb4b16;
}
.theme-solarized #gmail-header-row, .theme-solarized #drive-header-row, .theme-solarized #contacts-header-row, .theme-solarized .view-header-row {
    background: #073642;
    border-bottom: solid #586e75;
}
.theme-solarized #calendar-detail,
.theme-solarized #doc-viewer,
.theme-solarized #sheet-grid,
.theme-solarized #chat-message-pane,
.theme-solarized #contact-detail,
.theme-solarized #tasks-table {
    background: #073642;
    border-left: solid #586e75;
}
.theme-solarized #ai-drawer {
    background: #073642;
    border-left: solid #586e75;
}
.theme-solarized #email-body-view,
.theme-solarized #meet-container,
.theme-solarized #zoom-container {
    background: #073642;
}
.theme-solarized Button.-primary {
    background: #268bd2;
    color: #002b36;
}
.theme-solarized Button.-success {
    background: #859900;
    color: #002b36;
}
.theme-solarized Button.-error {
    background: #dc322f;
    color: #002b36;
}
.theme-solarized DataTable {
    background: #002b36;
    color: #839496;
}
.theme-solarized RichLog {
    background: #073642;
    color: #839496;
}
.theme-solarized Input {
    background: #073642;
    color: #839496;
    border: solid #586e75;
}
.theme-solarized Tree {
    background: transparent;
    color: #839496;
}
.theme-solarized Tree > TreeNavigation {
    color: #839496;
}
.theme-solarized #ai-drawer {
    background: #073642;
    border-left: solid #586e75;
}
.theme-solarized #ai-header {
    background: #002b36;
    color: #268bd2;
    border-bottom: solid #586e75;
}
.theme-solarized .ai-message.user {
    background: #586e75;
    color: #93a1a1;
}
.theme-solarized .ai-message.gemini {
    background: #002b36;
    color: #859900;
    border-left: solid #859900;
}
.theme-solarized #dialog-container, .theme-solarized #gmail-compose-container {
    background: #073642;
    border: double #268bd2;
}
.theme-solarized .dialog-title {
    color: #cb4b16;
}
.theme-solarized .multi-line-input, .theme-solarized #email-body {
    background: #002b36;
    border: solid #586e75;
}
.theme-solarized #gemini-label {
    color: #859900;
}
.theme-solarized Footer {
    background: #073642;
    color: #93a1a1;
}

/* Remove default borders on ai-drawer now that we use a draggable splitter */
.theme-gruvbox #ai-drawer,
.theme-catppuccin #ai-drawer,
.theme-nord #ai-drawer,
.theme-dracula #ai-drawer,
.theme-monokai #ai-drawer,
.theme-solarized #ai-drawer {
    border-left: none;
}

/* Theme-specific splitter styles */
.theme-gruvbox #ai-splitter {
    background: #504945;
}
.theme-gruvbox #ai-splitter:hover {
    background: #fe8019;
}

.theme-catppuccin #ai-splitter {
    background: #313244;
}
.theme-catppuccin #ai-splitter:hover {
    background: #fab387;
}

.theme-nord #ai-splitter {
    background: #4c566a;
}
.theme-nord #ai-splitter:hover {
    background: #88c0d0;
}

.theme-dracula #ai-splitter {
    background: #44475a;
}
.theme-dracula #ai-splitter:hover {
    background: #bd93f9;
}

.theme-monokai #ai-splitter {
    background: #49483e;
}
.theme-monokai #ai-splitter:hover {
    background: #a6e22e;
}

.theme-solarized #ai-splitter {
    background: #586e75;
}
.theme-solarized #ai-splitter:hover {
    background: #268bd2;
}

/* ========================================================================= */
/* TOP/BOTTOM BARS — theme the Textual Header & Footer so they don't render   */
/* as an unstyled black band above/below the workspace.                       */
/* ========================================================================= */
Header, Footer {
    background: transparent;
}
.theme-gruvbox Header, .theme-gruvbox Footer,
.theme-gruvbox HeaderClock, .theme-gruvbox Footer > .footer--key {
    background: #1d2021;
    color: #fabd2f;
}
.theme-catppuccin Header, .theme-catppuccin Footer,
.theme-catppuccin HeaderClock, .theme-catppuccin Footer > .footer--key {
    background: #11111b;
    color: #89b4fa;
}
.theme-nord Header, .theme-nord Footer,
.theme-nord HeaderClock, .theme-nord Footer > .footer--key {
    background: #2e3440;
    color: #88c0d0;
}
.theme-dracula Header, .theme-dracula Footer,
.theme-dracula HeaderClock, .theme-dracula Footer > .footer--key {
    background: #282a36;
    color: #bd93f9;
}
.theme-monokai Header, .theme-monokai Footer,
.theme-monokai HeaderClock, .theme-monokai Footer > .footer--key {
    background: #272822;
    color: #66d9ef;
}
.theme-solarized Header, .theme-solarized Footer,
.theme-solarized HeaderClock, .theme-solarized Footer > .footer--key {
    background: #002b36;
    color: #268bd2;
}
